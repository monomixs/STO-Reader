<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="24dp"
    android:paddingBottom="36dp">

    <!-- Handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="@color/surface3"/>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Story"
        android:textColor="@color/accent"
        android:textSize="22sp"
        android:fontFamily="serif"
        android:layout_marginBottom="18dp"/>

    <!-- Field label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TITLE"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <!-- Input -->
    <EditText
        android:id="@+id/newTitleInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="My Awesome Story"
        android:textColorHint="@color/text_muted"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:background="@drawable/bg_card"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:inputType="text"
        android:singleLine="true"
        android:layout_marginBottom="16dp"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cancel"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:background="@drawable/bg_btn_ghost"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnCreate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Create Story"
            android:textColor="#1A1408"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingTop="11dp"
            android:paddingBottom="11dp"
            android:background="@drawable/bg_btn_primary"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>
</LinearLayout>