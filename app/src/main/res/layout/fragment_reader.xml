<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Main content column -->
    <LinearLayout
        android:id="@+id/mainColumn"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

<!-- TOP BAR -->
<LinearLayout
    android:id="@+id/topBar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="14dp"
    android:background="@color/bg">

    <!-- Save to recent (shown only when opened from file manager) -->
    <TextView
        android:id="@+id/btnSaveToRecent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_ghost"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:layout_marginStart="8dp"
        android:drawableStart="@drawable/ic_save"
        android:drawablePadding="6dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Edit file (shown only when opened from file manager) -->
    <TextView
        android:id="@+id/btnEditFile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit"
        android:textColor="#1A1408"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_primary"
        android:paddingStart="12dp"
        android:paddingEnd="16dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:layout_marginStart="8dp"
        android:drawableStart="@drawable/ic_edit"
        android:drawablePadding="6dp"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>

        <!-- DIVIDER -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface3"/>

        <!-- SCROLLABLE CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="32dp"
                android:paddingBottom="100dp">

                <!-- Story title -->
                <TextView
                    android:id="@+id/readerStoryTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="32sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.2"
                    android:gravity="center"
                    android:layout_marginBottom="6dp"/>

                <!-- Chapter label -->
                <TextView
                    android:id="@+id/readerChapterLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:textSize="17sp"
                    android:fontFamily="serif"
                    android:letterSpacing="0.05"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="28dp"/>

                <!-- Chapter episodes list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEpisodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"/>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- Floating PREV button (bottom left) -->
    <TextView
        android:id="@+id/btnPrev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="32dp"
        android:text="Prev"
        android:textColor="#1A1408"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_primary"
        android:paddingStart="16dp"
        android:paddingEnd="22dp"
        android:paddingTop="13dp"
        android:paddingBottom="13dp"
        android:drawableStart="@drawable/ic_prev"
        android:drawablePadding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="6dp"
        android:visibility="gone"/>

    <!-- Cover Page -->
    <LinearLayout
        android:id="@+id/coverLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:elevation="8dp">

            <TextView
                android:id="@+id/coverTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Story Title"
                android:textColor="@color/accent"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/coverAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By Author"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/coverGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genre"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/coverChapters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chapters: 0"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/coverEpisodes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Episodes: 0"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"/>

            </LinearLayout>

            <!-- Description/Synopsis -->
            <TextView
                android:id="@+id/coverDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description goes here..."
                android:textColor="@color/text_muted"
                android:textSize="14sp"
                android:gravity="center"
                android:maxLines="5"
                android:ellipsize="end"
                android:layout_marginBottom="24dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/btnStartReading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Reading"
                android:textColor="#1A1408"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_primary"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Floating NEXT button (bottom right) -->
    <TextView
        android:id="@+id/btnNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="32dp"
        android:text="Next"
        android:textColor="#1A1408"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_primary"
        android:paddingStart="22dp"
        android:paddingEnd="16dp"
        android:paddingTop="13dp"
        android:paddingBottom="13dp"
        android:drawableEnd="@drawable/ic_next"
        android:drawablePadding="8dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="6dp"/>

    <!-- Nav bar spacer (inside FrameLayout, sits at bottom of mainColumn via gravity) -->
    <View
        android:id="@+id/navBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_gravity="bottom"/>

</FrameLayout>