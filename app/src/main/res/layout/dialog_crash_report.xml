<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:padding="24dp">

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Last session crashed"
            android:textColor="@color/danger"
            android:textSize="18sp"
            android:fontFamily="serif"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnCopyCrash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Copy"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_ghost"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Here's what caused it:"
        android:textColor="@color/text_muted"
        android:textSize="13sp"
        android:layout_marginBottom="12dp"/>

    <!-- Scrollable log box -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/crashLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.4"
            android:background="@color/surface2"
            android:padding="12dp"
            android:textIsSelectable="true"/>
    </ScrollView>

    <!-- Dismiss button -->
    <TextView
        android:id="@+id/btnDismissCrash"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Got it"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/bg_btn_ghost"
        android:paddingTop="11dp"
        android:paddingBottom="11dp"
        android:clickable="true"
        android:focusable="true"/>
</LinearLayout>