<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="12dp">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surface3"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/inputEpNumber"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:hint="Ep #"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:background="@drawable/bg_card"
            android:padding="8dp"
            android:inputType="text"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/inputEpName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Episode Name"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:background="@drawable/bg_card"
            android:padding="8dp"
            android:inputType="text"/>

        <TextView
            android:id="@+id/btnDeleteEp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="@color/danger"
            android:textSize="16sp"
            android:padding="8dp"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <EditText
        android:id="@+id/inputEpContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Write episode content here..."
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:background="@drawable/bg_card"
        android:padding="10dp"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:gravity="top"/>

</LinearLayout>