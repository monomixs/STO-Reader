<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:id="@+id/mainColumn"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="40dp"
            android:paddingEnd="40dp"
            android:paddingBottom="14dp"
            android:background="@color/bg">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:id="@+id/btnSaveToRecent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_ghost"
                android:paddingStart="16dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginStart="12dp"
                app:drawableStartCompat="@drawable/ic_save"
                android:drawablePadding="8dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/btnEditFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Edit"
                android:textColor="#1A1408"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_primary"
                android:paddingStart="16dp"
                android:paddingEnd="20dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginStart="12dp"
                app:drawableStartCompat="@drawable/ic_edit"
                android:drawablePadding="8dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface3"/>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="60dp"
                android:paddingBottom="120dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    app:layout_constraintWidth_max="700dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:paddingStart="40dp"
                    android:paddingEnd="40dp">

                    <TextView
                        android:id="@+id/readerStoryTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:textSize="44sp"
                        android:fontFamily="serif"
                        android:textStyle="bold"
                        android:lineSpacingMultiplier="1.2"
                        android:gravity="center"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/readerChapterLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent"
                        android:textSize="22sp"
                        android:fontFamily="serif"
                        android:letterSpacing="0.05"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:layout_marginBottom="48dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvEpisodes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <TextView
        android:id="@+id/btnPrev"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="40dp"
        android:text="Prev"
        android:textColor="#1A1408"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_primary"
        android:paddingStart="20dp"
        android:paddingEnd="32dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        app:drawableStartCompat="@drawable/ic_prev"
        android:drawablePadding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp"
        android:visibility="gone"/>

    <LinearLayout
        android:id="@+id/coverLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:padding="60dp"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintWidth_max="600dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="60dp"
            android:elevation="12dp">

            <TextView
                android:id="@+id/coverTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Story Title"
                android:textColor="@color/accent"
                android:textSize="40sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/coverAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="By Author"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/coverGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Genre"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/coverChapters"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chapters: 0"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/coverEpisodes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Episodes: 0"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/coverDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description goes here..."
                android:textColor="@color/text_muted"
                android:textSize="18sp"
                android:gravity="center"
                android:maxLines="8"
                android:ellipsize="end"
                android:layout_marginBottom="40dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/btnStartReading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Reading"
                android:textColor="#1A1408"
                android:textSize="18sp"
                android:textStyle="bold"
                android:background="@drawable/bg_btn_primary"
                android:paddingStart="48dp"
                android:paddingEnd="48dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btnNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="40dp"
        android:text="Next"
        android:textColor="#1A1408"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_btn_primary"
        android:paddingStart="32dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        app:drawableEndCompat="@drawable/ic_next"
        android:drawablePadding="12dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="8dp"/>

    <View
        android:id="@+id/navBarSpacer"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_gravity="bottom"/>

</FrameLayout>